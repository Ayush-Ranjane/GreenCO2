# ─────────────────────────────────────────────────────────────────────────────
# .env.production.example — GreenCO2 Production Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy to backend/.env and fill in real values before running docker-compose.
#   cp .env.production.example backend/.env
# NEVER commit the real .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=production
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_NAME=greenco2
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_HOST=db                          # Docker service name — do not change
DB_PORT=5432
DB_SSLMODE=prefer

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your production domain (no trailing slash)
CORS_ORIGINS=http://your-domain.com

# ── SMTP / Email Alerts ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587                        # 587 = STARTTLS | 465 = SSL
SMTP_USER=your@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx   # Gmail App Password (not account password)
ALERT_FROM=GreenCO2 Alerts <your@gmail.com>
# ALERT_REPLY_TO=no-reply@yourdomain.com
