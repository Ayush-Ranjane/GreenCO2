# ─────────────────────────────────────────────────────────────────────────────
# .env.example — GreenCO2 Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_NAME=greenco2
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost            # Use 'db' when running via docker-compose
DB_PORT=5432

# ── JWT Authentication ────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-string-in-production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slashes)
CORS_ORIGINS=http://localhost:3000

# ── SMTP / Email Alerts ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587                # 587 = STARTTLS | 465 = SSL
SMTP_USER=your@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx   # Gmail App Password (not account password)
ALERT_FROM=GreenCO2 Alerts <your@gmail.com>
# ALERT_REPLY_TO=no-reply@yourdomain.com   # optional
